{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Tiny 웹 서버 디버그",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/webproxy-lab/tiny/tiny",
            "args": [
                "8000"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/webproxy-lab/tiny",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "Tiny 서버 정리 후 빌드",
            "setupCommands": [
                {
                    "description": "gdb의 pretty-printing 활성화",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "디스어셈블리 형식을 Intel 방식으로 설정",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "follow-fork-mode를 parent로 설정",
                    "text": "-gdb-set follow-fork-mode parent",
                    "ignoreFailures": false
                },
                // {
                //     "description": "follow-fork-mode를 child로 설정",
                //     "text": "-gdb-set follow-fork-mode child",
                //     "ignoreFailures": false
                // },
                {
                    "description": "detach-on-fork를 on으로 설정",
                    "text": "-gdb-set detach-on-fork on",
                    "ignoreFailures": false
                }
                // {
                //     "description": "detach-on-fork를 off로 설정",
                //     "text": "-gdb-set detach-on-fork off",
                //     "ignoreFailures": false
                // }
            ],
            "sourceFileMap": {
                "/workspaces/webproxy_lab_docker": "${workspaceFolder}"
            }
        },
        {
            "name": "프록시 서버 디버그",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/webproxy-lab/proxy",
            "args": [
                "4500"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/webproxy-lab",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "프록시 서버 정리 후 빌드",
            "setupCommands": [
                {
                    "description": "gdb의 pretty-printing 활성화",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "디스어셈블리 형식을 Intel 방식으로 설정",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "follow-fork-mode를 parent로 설정",
                    "text": "-gdb-set follow-fork-mode parent",
                    "ignoreFailures": false
                },
                // {
                //     "description": "follow-fork-mode를 child로 설정",
                //     "text": "-gdb-set follow-fork-mode child",
                //     "ignoreFailures": false
                // },
                {
                    "description": "detach-on-fork를 on으로 설정",
                    "text": "-gdb-set detach-on-fork on",
                    "ignoreFailures": false
                }
                // {
                //     "description": "detach-on-fork를 off로 설정",
                //     "text": "-gdb-set detach-on-fork off",
                //     "ignoreFailures": false
                // }
            ],
            "sourceFileMap": {
                "/workspaces/webproxy_lab_docker": "${workspaceFolder}"
            }
        }
    ]
}
