{
    "version": 4,
    "configurations": [
        {
            "name": "Dev Container Linux",
            "compilerPath": "/usr/bin/gcc",
            "intelliSenseMode": "${default}",
            "cStandard": "gnu11",
            "includePath": [
                "${workspaceFolder}/webproxy-lab/**",
                "${workspaceFolder}/webproxy-lab/tiny/**",
                "/usr/include/**",
                "/usr/local/include/**"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/webproxy-lab",
                    "${workspaceFolder}/webproxy-lab/tiny",
                    "/usr/include",
                    "/usr/local/include"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ]
}
