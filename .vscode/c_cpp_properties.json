{
    "version": 4,
    "configurations": [
        {
            "name": "Dev Container Linux",
            "compilerPath": "/usr/bin/gcc",
            "intelliSenseMode": "linux-gcc-x64",
            "cStandard": "c11",
            "includePath": [
                "${workspaceFolder}/webproxy-lab/**",
                "${workspaceFolder}/webproxy-lab/tiny/**",
                "/usr/include",
                "/usr/include/x86_64-linux-gnu",
                "/usr/local/include"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/webproxy-lab",
                    "${workspaceFolder}/webproxy-lab/tiny",
                    "/usr/include",
                    "/usr/include/x86_64-linux-gnu",
                    "/usr/local/include"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ]
}
